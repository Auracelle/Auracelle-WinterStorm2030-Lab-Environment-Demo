# Copy this file to .streamlit/secrets.toml and fill in real values from your Supabase project.
# .streamlit/secrets.toml is gitignored -- never commit the real one.
#
# Where to find these: Supabase dashboard -> your project -> Settings -> API
#   url = "Project URL"
#   key = "anon public" key (NOT the service_role key -- anon is fine given Row Level
#         Security policies from supabase_setup.sql; service_role bypasses RLS entirely
#         and should not be used in a client-facing app like this one)

[supabase]
url = "https://your-project-ref.supabase.co"
key = "your-anon-public-key"
